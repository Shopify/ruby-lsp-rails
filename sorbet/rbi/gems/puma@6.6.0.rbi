# Puma deliberately avoids the use of the json gem and instead performs JSON
# serialization without any external dependencies. In a puma cluster, loading
# any gem into the puma master process means that operators cannot use a
# phased restart to upgrade their application if the new version of that
# application uses a different version of that gem. The json gem in
# particular is additionally problematic because it leverages native
# extensions. If the puma master process relies on a gem with native
# extensions and operators remove gems from disk related to old releases,
# subsequent phased restarts can fail.
#
# The implementation of JSON serialization in this module is not designed to
# be particularly full-featured or fast. It just has to handle the few places
# where Puma relies on JSON serialization internally.
#
# pkg:gem/puma#lib/puma/json_serialization.rb:20
module Puma::JSONSerialization
  class << self
    # pkg:gem/puma#lib/puma/json_serialization.rb:29
    def generate(value); end

    private

    # pkg:gem/puma#lib/puma/json_serialization.rb:86
    def serialize_object_key(output, value); end

    # pkg:gem/puma#lib/puma/json_serialization.rb:71
    def serialize_string(output, value); end

    # pkg:gem/puma#lib/puma/json_serialization.rb:38
    def serialize_value(output, value); end
  end
end

# pkg:gem/puma#lib/puma/json_serialization.rb:22
Puma::JSONSerialization::BACKSLASH = T.let(T.unsafe(nil), Regexp)

# As required by ECMA-404
#
# pkg:gem/puma#lib/puma/json_serialization.rb:24
Puma::JSONSerialization::CHAR_TO_ESCAPE = T.let(T.unsafe(nil), Regexp)

# pkg:gem/puma#lib/puma/json_serialization.rb:23
Puma::JSONSerialization::CONTROL_CHAR_TO_ESCAPE = T.let(T.unsafe(nil), Regexp)

# pkg:gem/puma#lib/puma/json_serialization.rb:21
Puma::JSONSerialization::QUOTE = T.let(T.unsafe(nil), Regexp)

# pkg:gem/puma#lib/puma/json_serialization.rb:26
class Puma::JSONSerialization::SerializationError < ::StandardError; end

# Puma::Launcher is the single entry point for starting a Puma server based on user
# configuration. It is responsible for taking user supplied arguments and resolving them
# with configuration in `config/puma.rb` or `config/puma/<env>.rb`.
#
# It is responsible for either launching a cluster of Puma workers or a single
# puma server.
#
# pkg:gem/puma#lib/puma/launcher.rb:18
class Puma::Launcher
  # Returns an instance of Launcher
  #
  # +conf+ A Puma::Configuration object indicating how to run the server.
  #
  # +launcher_args+ A Hash that currently has one required key `:events`,
  # this is expected to hold an object similar to an `Puma::LogWriter.stdio`,
  # this object will be responsible for broadcasting Puma's internal state
  # to a logging destination. An optional key `:argv` can be supplied,
  # this should be an array of strings, these arguments are re-used when
  # restarting the puma server.
  #
  # Examples:
  #
  #   conf = Puma::Configuration.new do |user_config|
  #     user_config.threads 1, 10
  #     user_config.app do |env|
  #       [200, {}, ["hello world"]]
  #     end
  #   end
  #   Puma::Launcher.new(conf, log_writer: Puma::LogWriter.stdio).run
  #
  # pkg:gem/puma#lib/puma/launcher.rb:41
  def initialize(conf, launcher_args = T.unsafe(nil)); end

  # pkg:gem/puma#lib/puma/launcher.rb:113
  def binder; end

  # pkg:gem/puma#lib/puma/launcher.rb:225
  def close_binder_listeners; end

  # pkg:gem/puma#lib/puma/launcher.rb:113
  def config; end

  # Return all tcp ports the launcher may be using, TCP or SSL
  # @!attribute [r] connected_ports
  # @version 5.0.0
  #
  # pkg:gem/puma#lib/puma/launcher.rb:211
  def connected_ports; end

  # Delete the configured pidfile
  #
  # pkg:gem/puma#lib/puma/launcher.rb:141
  def delete_pidfile; end

  # pkg:gem/puma#lib/puma/launcher.rb:113
  def events; end

  # Begin async shutdown of the server
  #
  # pkg:gem/puma#lib/puma/launcher.rb:147
  def halt; end

  # pkg:gem/puma#lib/puma/launcher.rb:113
  def log_writer; end

  # pkg:gem/puma#lib/puma/launcher.rb:113
  def options; end

  # Begin a phased restart if supported
  #
  # pkg:gem/puma#lib/puma/launcher.rb:165
  def phased_restart; end

  # Begin a refork if supported
  #
  # pkg:gem/puma#lib/puma/launcher.rb:181
  def refork; end

  # Begin async restart of the server
  #
  # pkg:gem/puma#lib/puma/launcher.rb:159
  def restart; end

  # @!attribute [r] restart_args
  #
  # pkg:gem/puma#lib/puma/launcher.rb:216
  def restart_args; end

  # pkg:gem/puma#lib/puma/launcher.rb:113
  def restart_dir; end

  # Run the server. This blocks until the server is stopped
  #
  # pkg:gem/puma#lib/puma/launcher.rb:192
  def run; end

  # Return stats about the server
  #
  # pkg:gem/puma#lib/puma/launcher.rb:116
  def stats; end

  # Begin async shutdown of the server gracefully
  #
  # pkg:gem/puma#lib/puma/launcher.rb:153
  def stop; end

  # @!attribute [r] thread_status
  # @version 5.0.0
  #
  # pkg:gem/puma#lib/puma/launcher.rb:236
  def thread_status; end

  # Write a state file that can be used by pumactl to control
  # the server
  #
  # pkg:gem/puma#lib/puma/launcher.rb:122
  def write_state; end

  private

  # pkg:gem/puma#lib/puma/launcher.rb:337
  def clustered?; end

  # pkg:gem/puma#lib/puma/launcher.rb:274
  def do_forceful_stop; end

  # pkg:gem/puma#lib/puma/launcher.rb:279
  def do_graceful_stop; end

  # pkg:gem/puma#lib/puma/launcher.rb:284
  def do_restart(previous_env); end

  # pkg:gem/puma#lib/puma/launcher.rb:261
  def do_run_finished(previous_env); end

  # @!attribute [r] environment
  #
  # pkg:gem/puma#lib/puma/launcher.rb:363
  def environment; end

  # pkg:gem/puma#lib/puma/launcher.rb:376
  def generate_restart_data; end

  # pkg:gem/puma#lib/puma/launcher.rb:249
  def get_env; end

  # pkg:gem/puma#lib/puma/launcher.rb:333
  def log(str); end

  # pkg:gem/puma#lib/puma/launcher.rb:488
  def log_config; end

  # pkg:gem/puma#lib/puma/launcher.rb:371
  def prune_bundler!; end

  # pkg:gem/puma#lib/puma/launcher.rb:367
  def prune_bundler?; end

  # pkg:gem/puma#lib/puma/launcher.rb:329
  def reload_worker_directory; end

  # pkg:gem/puma#lib/puma/launcher.rb:291
  def restart!; end

  # pkg:gem/puma#lib/puma/launcher.rb:346
  def set_process_title; end

  # pkg:gem/puma#lib/puma/launcher.rb:357
  def set_rack_environment; end

  # pkg:gem/puma#lib/puma/launcher.rb:421
  def setup_signals; end

  # @!attribute [r] title
  #
  # pkg:gem/puma#lib/puma/launcher.rb:351
  def title; end

  # pkg:gem/puma#lib/puma/launcher.rb:341
  def unsupported(str); end

  # If configured, write the pid of the current process out
  # to a file.
  #
  # pkg:gem/puma#lib/puma/launcher.rb:319
  def write_pid; end
end

